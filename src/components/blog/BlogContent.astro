---
// Wrapper component for rendered blog post markdown content.
// Provides scoped styles that handle:
//   - Legacy HTML tables with hardcoded width attributes
//   - Image containment and spacing
//   - Code block styling on bg-base-200 cards
//   - Consistent typography and spacing
---

<div class="blog-content prose prose-lg max-w-none">
  <slot />
</div>

<style>
  .blog-content {
    overflow-x: auto;
  }

  /* Headings */
  .blog-content :global(h1),
  .blog-content :global(h2),
  .blog-content :global(h3),
  .blog-content :global(h4) {
    font-weight: 700;
    color: oklch(var(--bc));
  }

  /* Links */
  .blog-content :global(a) {
    color: oklch(var(--p));
    text-decoration: none;
  }

  .blog-content :global(a:hover) {
    text-decoration: underline;
  }

  /* Code blocks — Shiki applies inline dark background, so just handle
     spacing, rounding, and overflow. Don't fight the inline styles. */
  .blog-content :global(pre) {
    border-radius: var(--rounded-box, 0.5rem) !important;
    margin-top: 1.5rem !important;
    margin-bottom: 1.5rem !important;
    padding: 1.25rem !important;
    overflow-x: auto;
  }

  /* Inline code (not inside pre) */
  .blog-content :global(:not(pre) > code) {
    background-color: oklch(var(--bc) / 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-weight: 400;
  }

  .blog-content :global(code)::before,
  .blog-content :global(code)::after {
    content: none;
  }

  .blog-content :global(pre code) {
    background-color: transparent;
    padding: 0;
    border-radius: 0;
  }

  /* Blockquotes */
  .blog-content :global(blockquote) {
    border-left-color: oklch(var(--p));
    color: oklch(var(--bc) / 0.8);
  }

  /* Images — contained with spacing */
  .blog-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--rounded-box, 0.5rem);
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }

  /* Legacy HTML tables with hardcoded width attributes */
  .blog-content :global(table) {
    width: 100% !important;
    max-width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    margin: 1rem 0;
  }

  .blog-content :global(td),
  .blog-content :global(th) {
    width: auto !important;
    padding: 0.5rem 0.75rem;
    vertical-align: top;
    border-bottom: 1px solid oklch(var(--bc) / 0.1);
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .blog-content :global(td:first-child) {
    width: 30% !important;
    font-weight: 500;
    white-space: nowrap;
  }
</style>
