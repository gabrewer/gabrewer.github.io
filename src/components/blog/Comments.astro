---
interface Props {
  url: string;
  title: string;
}

const { url, title } = Astro.props;
const canonicalUrl = url.replace(/^https?:\/\/localhost:\d+/, 'https://gabrewer.com');
---

<section aria-label="Comments" class="space-y-4">
  <h2 class="text-xl font-semibold">Comments</h2>
  <div id="remark42"></div>
</section>

<script define:vars={{ canonicalUrl, title }}>
  window.remark_config = {
    host: 'https://comments.gabrewer.com',
    site_id: 'gabrewer',
    url: canonicalUrl,
    title: title,
    components: ['embed'],
    theme: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light',
  };

  (function () {
    var script = document.createElement('script');
    script.src = window.remark_config.host + '/web/embed.js';
    script.defer = true;
    document.head.appendChild(script);
  })();
</script>
