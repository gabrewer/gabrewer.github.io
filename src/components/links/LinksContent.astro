---
// Wrapper component for rendered links/roundup markdown content.
// Provides scoped styles that target the rendered HTML structure:
//   h4  → bold category section headers
//   blockquote → featured quote callout card
//   p > a:only-child → bulleted clickable link items
---

<div class="links-content">
  <slot />
</div>

<style>
  .links-content :global(h4) {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: oklch(var(--p));
    border-bottom: 2px solid oklch(var(--p) / 0.2);
    padding-bottom: 0.375rem;
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .links-content :global(h4:first-child) {
    margin-top: 0;
  }

  /* Quote of the Day — featured callout */
  .links-content :global(blockquote) {
    background-color: oklch(var(--b2));
    border-left: 4px solid oklch(var(--p));
    border-radius: var(--rounded-box, 1rem);
    padding: 1.25rem 1.5rem;
    margin: 1rem 0;
    font-style: italic;
    color: oklch(var(--bc) / 0.85);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .links-content :global(blockquote p) {
    margin: 0;
  }

  /* Paragraphs that contain only a link — render as bulleted list items */
  .links-content :global(p:has(> a:only-child)) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0.25rem 0;
    padding-left: 0.25rem;
  }

  .links-content :global(p:has(> a:only-child))::before {
    content: "›";
    color: oklch(var(--p));
    font-weight: 700;
    flex-shrink: 0;
  }

  .links-content :global(a) {
    color: oklch(var(--p));
    text-decoration: none;
    transition: color 0.15s;
  }

  .links-content :global(a:hover) {
    text-decoration: underline;
  }

  /* Regular paragraphs (non-link) */
  .links-content :global(p) {
    margin: 0.5rem 0;
    line-height: 1.6;
  }
</style>
