---
import status from '../../data/status.json';
---

<div class="flex justify-center">
  <div class="inline-flex items-center gap-2.5 bg-base-200 border border-base-300 rounded-full px-5 py-2.5 text-sm text-base-content/80">
    <span class="inline-block w-2 h-2 rounded-full bg-primary animate-pulse shrink-0" aria-hidden="true"></span>
    <span>{status.text}</span>
  </div>
</div>
