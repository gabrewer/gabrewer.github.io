---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const POSTS_PER_PAGE = 10;

export async function getStaticPaths() {
  const postsPerPage = 10;
  const posts = await getCollection('links');
  const totalPages = Math.ceil(posts.length / postsPerPage);

  // Generate pages 2..N (page 1 is index.astro)
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const page = Number(Astro.params.page);
const posts = await getCollection('links');
const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const totalPages = Math.ceil(sorted.length / POSTS_PER_PAGE);

const paged = sorted.slice((page - 1) * POSTS_PER_PAGE, page * POSTS_PER_PAGE);

const rendered = await Promise.all(
  paged.map(async (post) => {
    const { Content } = await post.render();
    return { post, Content };
  })
);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const newerHref = page === 2 ? '/links' : `/links/${page - 1}`;
---

<BaseLayout
  title={`Useful Links — Page ${page} — Greg Brewer`}
  description="Daily curated links covering AI, software engineering, architecture, leadership, and tools worth reading."
>
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-10">

    <header class="space-y-2">
      <h1 class="text-4xl font-bold">Useful Links</h1>
      <p class="text-base-content/70">
        {sorted.length} roundups — curated links on AI, engineering, leadership, and more.
      </p>
    </header>

    <!-- Feed: full content inline -->
    <div class="space-y-10">
      {rendered.map(({ post, Content }) => (
        <article class="bg-base-200 rounded-box p-6 md:p-8 space-y-4">
          <header class="space-y-1 pb-4 border-b border-base-300">
            <time
              datetime={post.data.date.toISOString()}
              class="text-sm font-medium text-primary"
            >
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-xl font-bold">
              <a href={`/links/${post.slug}`} class="hover:text-primary transition-colors">
                {post.data.title}
              </a>
            </h2>
          </header>

          <div class="prose max-w-none
            prose-headings:font-bold prose-headings:text-base-content
            prose-h4:text-sm prose-h4:font-semibold prose-h4:text-base-content/70 prose-h4:uppercase prose-h4:tracking-wide prose-h4:mt-4 prose-h4:mb-1
            prose-p:my-1
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-blockquote:border-primary prose-blockquote:text-base-content/80 prose-blockquote:font-normal
            prose-ul:my-1 prose-li:my-0
          ">
            <Content />
          </div>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    <nav aria-label="Pagination" class="flex justify-center items-center gap-2 pt-4">
      <a href={newerHref} class="btn btn-ghost btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Newer
      </a>

      <span class="text-sm text-base-content/60">
        Page {page} of {totalPages}
      </span>

      {page < totalPages ? (
        <a href={`/links/${page + 1}`} class="btn btn-ghost btn-sm">
          Older
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      ) : (
        <span class="btn btn-ghost btn-sm btn-disabled">
          Older
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </span>
      )}
    </nav>

  </div>
</BaseLayout>
