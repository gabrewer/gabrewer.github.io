---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogContent from '../../components/blog/BlogContent.astro';

const blogPosts = await getCollection('blog');
const sorted = blogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const rendered = await Promise.all(
  sorted.map(async (post) => {
    const { Content } = await post.render();
    return { post, Content };
  })
);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog — Greg Brewer"
  description="Writing on AI engineering, modern software architecture, engineering leadership, and the future of software development."
>
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-10">

    <header class="space-y-2">
      <h1 class="text-4xl font-bold">Blog</h1>
      <p class="text-base-content/70">
        Writing on AI engineering, software architecture, and leadership.
      </p>
    </header>

    <div class="space-y-10">
      {rendered.map(({ post, Content }) => (
        <article class="bg-base-200 rounded-box p-6 md:p-8">
          <header class="space-y-1 pb-4 mb-6 border-b border-base-300">
            <time
              datetime={post.data.date.toISOString()}
              class="text-sm font-medium text-primary"
            >
              {formatDate(post.data.date)}
            </time>
            <h2 class="text-xl font-bold">
              <a href={`/blog/${post.slug}`} class="hover:text-primary transition-colors">
                {post.data.title}
              </a>
            </h2>
            {post.data.categories && post.data.categories.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-1">
                {post.data.categories.map((cat: string) => (
                  <span class="badge badge-sm badge-ghost">{cat}</span>
                ))}
              </div>
            )}
          </header>

          <BlogContent>
            <Content />
          </BlogContent>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
