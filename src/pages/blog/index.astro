---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = await getCollection('blog');
const sorted = blogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="Blog — Greg Brewer"
  description="Writing on AI engineering, modern software architecture, engineering leadership, and the future of software development."
>
  <div class="max-w-4xl mx-auto px-4 py-12 space-y-10">

    <header class="space-y-2">
      <h1 class="text-4xl font-bold">Blog</h1>
      <p class="text-base-content/70">
        Writing on AI engineering, software architecture, and leadership.
      </p>
    </header>

    <div class="space-y-6">
      {sorted.map((post) => (
        <article class="border-b border-base-200 pb-6 last:border-0">
          <h2 class="text-xl font-medium mb-1">
            <a href={`/blog/${post.slug}`} class="text-primary hover:underline">
              {post.data.title}
            </a>
          </h2>
          <time
            datetime={post.data.date.toISOString()}
            class="text-sm text-base-content/50 block mb-2"
          >
            {formatDate(post.data.date)}
          </time>
          {post.data.categories && post.data.categories.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-2">
              {post.data.categories.map((cat: string) => (
                <span class="badge badge-sm badge-ghost">{cat}</span>
              ))}
            </div>
          )}
          {post.data.description && (
            <p class="text-base-content/70">{post.data.description}</p>
          )}
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
