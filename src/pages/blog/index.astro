---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Blog posts only — link roundups live at /links
const blogPosts = await getCollection('blog');
const sorted = blogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

// Group by year for display
const byYear = new Map<number, typeof sorted>();
for (const post of sorted) {
  const year = post.data.date.getFullYear();
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(post);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);
---

<BaseLayout
  title="Blog — Greg Brewer"
  description="Writing on AI engineering, modern software architecture, engineering leadership, and the future of software development."
>
  <div class="max-w-2xl mx-auto px-4 py-12 space-y-10">

    <!-- Header -->
    <header class="space-y-2">
      <h1 class="text-4xl font-bold">Blog</h1>
      <p class="text-base-content/70">
        {sorted.length} posts — writing on AI engineering, software architecture, and leadership
      </p>
      <p class="text-sm text-base-content/50">
        Looking for curated links? See the <a href="/links" class="text-primary hover:underline">Link Roundups</a> archive.
      </p>
    </header>

    <!-- Posts by year -->
    <div class="space-y-10">
      {years.map((year) => (
        <section aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`} class="text-xl font-bold text-base-content/40 mb-3 pb-2 border-b border-base-300">
            {year}
          </h2>
          <ul class="space-y-0" role="list">
            {byYear.get(year)!.map((post) => (
              <li>
                <a
                  href={`/blog/${post.slug}`}
                  class="group flex items-start justify-between gap-4 py-3 border-b border-base-200 last:border-0 hover:bg-base-200 -mx-3 px-3 rounded transition-colors"
                >
                  <span class="font-medium group-hover:text-primary transition-colors leading-snug">
                    {post.data.title}
                  </span>
                  <time
                    datetime={post.data.date.toISOString()}
                    class="text-sm text-base-content/40 shrink-0 whitespace-nowrap mt-0.5"
                  >
                    {formatDate(post.data.date)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

  </div>
</BaseLayout>
