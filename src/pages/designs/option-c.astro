---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import status from '../../data/status.json';

const bookingUrl =
  'https://outlook-sdf.office.com/bookwithme/user/9eb0e58935e84f68a9faccb3732b0077@lessi.ai?anonymous&ep=signature';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4)
  .map((p) => ({
    title: p.data.title,
    date: p.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
    isoDate: p.data.date.toISOString(),
    href: `/blog/${p.slug}`,
  }));
---

<BaseLayout
  title="Greg Brewer — Design Option C"
  description="Dashboard layout exploration for Greg Brewer's landing page."
>
  <div class="max-w-7xl mx-auto px-4 lg:px-8 py-8">

    <!-- Back link -->
    <a
      href="/designs"
      class="inline-flex items-center gap-1.5 text-sm text-base-content/50 hover:text-base-content transition-colors mb-8"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
      Back to designs
    </a>

    <!-- Design label -->
    <div class="flex items-center gap-3 mb-8 pb-6 border-b border-base-300">
      <span class="badge badge-accent">Option C</span>
      <span class="text-base-content/50 text-sm">Dashboard / Builder's Workbench — Card grid, information-dense</span>
    </div>

    <!-- ===== STATS STRIP ===== -->
    <div class="stats stats-horizontal w-full bg-base-200 border border-base-300 shadow-sm mb-8 overflow-x-auto">
      <div class="stat">
        <div class="stat-title">Experience</div>
        <div class="stat-value text-primary text-2xl">30+</div>
        <div class="stat-desc">Years building software</div>
      </div>
      <div class="stat">
        <div class="stat-title">Current Role</div>
        <div class="stat-value text-secondary text-xl leading-tight">Co-Founder</div>
        <div class="stat-desc">&amp; CTO, Lessi AI</div>
      </div>
      <div class="stat">
        <div class="stat-title">Focus Area</div>
        <div class="stat-value text-accent text-xl leading-tight">AI Systems</div>
        <div class="stat-desc">Agentic coding &amp; LLMs</div>
      </div>
      <div class="stat">
        <div class="stat-title">Speaking</div>
        <div class="stat-value text-2xl">UMich</div>
        <div class="stat-desc">EECS 441 Guest Lecturer</div>
      </div>
    </div>

    <!-- ===== LESSI AI — FEATURED WIDE CARD ===== -->
    <div class="card bg-primary text-primary-content border border-primary shadow-md mb-8">
      <div class="card-body">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div class="space-y-2 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="badge bg-primary-content/20 text-primary-content border-primary-content/30 font-bold uppercase tracking-wide text-xs">
                What I'm Building
              </span>
              <span class="badge bg-primary-content/20 text-primary-content border-primary-content/30 text-xs">
                Co-Founder &amp; CTO
              </span>
            </div>
            <h2 class="text-2xl font-black">Lessi AI</h2>
            <p class="text-primary-content/80 leading-relaxed text-sm max-w-xl">
              AI platform for <strong class="text-primary-content">special education teachers</strong> — generates lesson plans,
              assessments, reading passages, and instructional supports aligned with IEPs, state standards,
              and evidence-based instructional practices. Dramatically reduces prep time while improving instruction quality.
            </p>
          </div>
          <div class="shrink-0">
            <a
              href="https://www.lessi.ai"
              target="_blank"
              rel="noopener noreferrer"
              class="btn bg-primary-content text-primary hover:bg-primary-content/90 border-0 font-bold"
            >
              Visit Lessi AI
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== MAIN CARD GRID: 3 columns on desktop, 1 on mobile ===== -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <!-- IDENTITY CARD -->
      <div class="card bg-base-200 border border-base-300">
        <div class="card-body">
          <div class="flex items-start gap-4">
            <!-- Avatar -->
            <div class="avatar shrink-0" role="img" aria-label="Greg Brewer profile photo placeholder">
              <div class="w-14 h-14 rounded-full bg-base-300 flex items-center justify-center ring-2 ring-primary ring-offset-2 ring-offset-base-200">
                <span class="text-lg font-bold text-base-content/30" aria-hidden="true">GB</span>
              </div>
            </div>
            <div>
              <h1 class="text-xl font-black leading-tight">Greg Brewer</h1>
              <p class="text-xs text-base-content/50 mt-0.5 font-medium">
                Founder &middot; CTO &middot; AI Engineer
              </p>
            </div>
          </div>

          <p class="text-sm text-base-content/80 leading-relaxed mt-2">
            Applying engineering discipline to the AI agentic coding landscape.
            I build systems that help people make better decisions.
          </p>

          <!-- Status indicator -->
          <div class="flex items-center gap-2 bg-base-300 rounded-full px-3 py-2 mt-2">
            <span class="inline-block w-2 h-2 rounded-full bg-success animate-pulse shrink-0" aria-hidden="true"></span>
            <span class="text-xs text-base-content/70 leading-snug">{status.text}</span>
          </div>

          <div class="card-actions mt-2">
            <a href="/about" class="btn btn-ghost btn-xs">Full background &rarr;</a>
          </div>
        </div>
      </div>

      <!-- LATEST WRITING CARD -->
      <div class="card bg-base-200 border border-base-300 md:col-span-1 lg:col-span-1">
        <div class="card-body">
          <div class="flex items-center justify-between mb-1">
            <h2 class="card-title text-base font-black uppercase tracking-wide">Latest Writing</h2>
            <a href="/blog" class="text-xs text-primary font-semibold hover:underline">All &rarr;</a>
          </div>

          <ul class="space-y-0.5" role="list">
            {posts.map((post) => (
              <li>
                <a
                  href={post.href}
                  class="group flex items-start justify-between gap-3 py-2.5 border-b border-base-300 last:border-0 hover:text-primary transition-colors"
                >
                  <span class="text-sm font-medium leading-snug group-hover:text-primary transition-colors flex-1">
                    {post.title}
                  </span>
                  <time
                    datetime={post.isoDate}
                    class="text-xs text-base-content/40 shrink-0 mt-0.5 whitespace-nowrap"
                  >
                    {post.date}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- SPEAKING CARD -->
      <div class="card bg-base-200 border border-base-300">
        <div class="card-body">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h2 class="card-title text-base font-black uppercase tracking-wide">Speaking</h2>
            <span class="badge badge-secondary badge-sm shrink-0">Guest Lecture</span>
          </div>

          <div class="space-y-3">
            <div class="border-l-4 border-secondary pl-3">
              <p class="text-xs font-bold uppercase tracking-widest text-base-content/50 mb-1">University of Michigan</p>
              <p class="font-bold text-sm leading-snug">&ldquo;Engineering in the Age of AI&rdquo;</p>
              <p class="text-xs text-base-content/60 mt-1">EECS 441 — Mobile App Dev for Entrepreneurs</p>
              <p class="text-xs text-base-content/70 mt-2 leading-relaxed">
                How AI tools reshape software development workflows for the next generation of engineers.
              </p>
            </div>

            <p class="text-xs text-base-content/50 leading-relaxed">
              Available for conference talks, team workshops, and guest lectures.
            </p>
          </div>
        </div>
      </div>

      <!-- TECHNICAL FOCUS CARD -->
      <div class="card bg-base-200 border border-base-300">
        <div class="card-body">
          <h2 class="card-title text-base font-black uppercase tracking-wide mb-2">Technical Focus</h2>
          <div class="space-y-3">
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-base-content/40 mb-1.5">Current Stack</p>
              <div class="flex flex-wrap gap-1.5">
                {['.NET / Aspire', 'Blazor', 'C#', 'PostgreSQL', 'Azure'].map((tech) => (
                  <span class="badge badge-ghost badge-sm font-medium">{tech}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-base-content/40 mb-1.5">AI Systems</p>
              <div class="flex flex-wrap gap-1.5">
                {['LLMs', 'RAG', 'Agent Workflows', 'AI Safety'].map((tech) => (
                  <span class="badge badge-primary badge-outline badge-sm font-medium">{tech}</span>
                ))}
              </div>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-base-content/40 mb-1.5">Architecture</p>
              <div class="flex flex-wrap gap-1.5">
                {['Event Sourcing', 'Multi-tenant SaaS', 'Distributed Caching'].map((tech) => (
                  <span class="badge badge-ghost badge-sm font-medium">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CONNECT CARD -->
      <div class="card bg-base-200 border border-base-300 md:col-span-2 lg:col-span-1">
        <div class="card-body">
          <h2 class="card-title text-base font-black uppercase tracking-wide mb-1">Connect</h2>
          <p class="text-sm text-base-content/70 leading-relaxed mb-3">
            Building in AI, need engineering leadership, or want to talk about the future of software?
          </p>

          <div class="space-y-2">
            <a
              href="mailto:greg@gabrewer.com"
              class="btn btn-primary btn-sm w-full justify-start gap-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
              Email Me
            </a>

            <a
              href={bookingUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline btn-sm w-full justify-start gap-2"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Book a Call
            </a>

            <div class="flex gap-2 pt-1">
              <a
                href="https://www.linkedin.com/in/gabrewer/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-ghost btn-sm flex-1 gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
              <a
                href="https://github.com/gabrewer"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-ghost btn-sm flex-1 gap-1.5"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
                GitHub
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
    <!-- /grid -->

  </div>
</BaseLayout>
