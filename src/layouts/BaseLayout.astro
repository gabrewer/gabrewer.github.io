---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
}

const {
  title = 'Greg Brewer — Founder · AI Engineer',
  description = 'Greg Brewer is a Founder and AI Engineer applying engineering discipline to the AI agentic coding landscape.',
  ogImage = '/og-image.png',
  canonicalUrl,
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://gabrewer.com';
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, siteUrl).toString();
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Greg Brewer Blog" href="/rss.xml" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Prevent theme flash: read localStorage before page renders -->
    <script is:inline>
      (function() {
        try {
          const saved = localStorage.getItem('theme');
          if (saved) {
            document.documentElement.setAttribute('data-theme', saved);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch(e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content flex flex-col">

    <!-- Navigation -->
    <header>
      <nav class="navbar bg-base-200 border-b border-base-300 px-4 lg:px-8 sticky top-0 z-40">
        <div class="navbar-start">
          <a href="/" class="btn btn-ghost text-lg font-bold tracking-tight gap-2">
            <div class="avatar">
              <div class="w-8 rounded-full">
                <img src="https://2.gravatar.com/avatar/9e475f93cce80d8702128abda3c29861197ddc3a84260c1abecee39470c1e442?s=64" alt="Greg Brewer" />
              </div>
            </div>
            Greg Brewer
          </a>
        </div>
        <div class="navbar-center hidden md:flex">
          <ul class="menu menu-horizontal px-1 gap-1">
            <li><a href="/" class={`rounded-btn font-medium${pathname === '/' ? ' text-primary font-semibold' : ''}`} aria-current={pathname === '/' ? 'page' : undefined}>Home</a></li>
            <li><a href="/blog" class={`rounded-btn font-medium${pathname.startsWith('/blog') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/blog') ? 'page' : undefined}>Blog</a></li>
            <li><a href="/links" class={`rounded-btn font-medium${pathname.startsWith('/links') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/links') ? 'page' : undefined}>Useful Links</a></li>
            <li><a href="/about" class={`rounded-btn font-medium${pathname.startsWith('/about') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/about') ? 'page' : undefined}>About</a></li>
          </ul>
        </div>
        <div class="navbar-end gap-2">
          <ThemeSwitcher />
          <!-- Mobile menu -->
          <div class="dropdown dropdown-end md:hidden" id="mobile-menu-dropdown">
            <button tabindex="0" id="mobile-menu-btn" class="btn btn-ghost btn-sm" aria-label="Open menu" aria-haspopup="menu" aria-expanded="false">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </button>
            <ul tabindex="0" role="menu" class="dropdown-content bg-base-200 border border-base-300 rounded-box z-50 mt-2 w-40 p-1 shadow-xl">
              <li role="none"><a href="/" role="menuitem" class={`block px-4 py-2 rounded-btn hover:bg-base-300 font-medium${pathname === '/' ? ' text-primary font-semibold' : ''}`} aria-current={pathname === '/' ? 'page' : undefined}>Home</a></li>
              <li role="none"><a href="/blog" role="menuitem" class={`block px-4 py-2 rounded-btn hover:bg-base-300 font-medium${pathname.startsWith('/blog') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/blog') ? 'page' : undefined}>Blog</a></li>
              <li role="none"><a href="/links" role="menuitem" class={`block px-4 py-2 rounded-btn hover:bg-base-300 font-medium${pathname.startsWith('/links') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/links') ? 'page' : undefined}>Useful Links</a></li>
              <li role="none"><a href="/about" role="menuitem" class={`block px-4 py-2 rounded-btn hover:bg-base-300 font-medium${pathname.startsWith('/about') ? ' text-primary font-semibold' : ''}`} aria-current={pathname.startsWith('/about') ? 'page' : undefined}>About</a></li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <!-- Page Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Mobile menu aria-expanded toggle -->
    <script is:inline>
      (function() {
        var btn = document.getElementById('mobile-menu-btn');
        var dropdown = document.getElementById('mobile-menu-dropdown');
        if (!btn || !dropdown) return;
        btn.addEventListener('click', function() {
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
        });
        dropdown.addEventListener('focusout', function(e) {
          if (!dropdown.contains(e.relatedTarget)) {
            btn.setAttribute('aria-expanded', 'false');
          }
        });
      })();
    </script>

    <!-- Footer -->
    <footer class="footer footer-center bg-base-200 border-t border-base-300 p-6 text-base-content/70">
      <p class="text-sm">
        &copy; {new Date().getFullYear()} Greg Brewer. Built with <a href="https://astro.build" class="link link-hover font-medium" target="_blank" rel="noopener noreferrer">Astro</a> &amp; <a href="https://daisyui.com" class="link link-hover font-medium" target="_blank" rel="noopener noreferrer">DaisyUI</a>.
      </p>
    </footer>

  </body>
</html>
